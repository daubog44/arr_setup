apiVersion: v1
kind: Service
metadata:
  name: falco-ingest
  namespace: security
  labels:
    app.kubernetes.io/name: falcosidekick
    app.kubernetes.io/instance: falco
    app.kubernetes.io/component: ingest
spec:
  type: NodePort
  selector:
    app.kubernetes.io/name: falcosidekick
    app.kubernetes.io/instance: falco
    app.kubernetes.io/component: core
  ports:
    - name: http
      protocol: TCP
      port: 2801
      targetPort: http
      nodePort: ${HAAC_FALCO_INGEST_NODEPORT}
