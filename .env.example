
# LXC Specific Variables
LXC_PASSWORD=your_lxc_password
LXC_MASTER_HOSTNAME=haacarr-master
# Worker nodes are now configured in tofu/workers.tfvars (Prettier & HCL-native!)





# --- Storage Configuration (Project v2) ---
# 1. NAS_ADDRESS: The IP/Hostname of the NAS device (e.g., 192.168.0.1)
NAS_ADDRESS=192.168.0.1
# 2. NAS_PATH: The export path as defined ON THE NAS (e.g., /media/nvme1/proxmox)
NAS_PATH=/media/nvme1/proxmox
# 3. HOST_NAS_PATH: The mount point ON THE PROXMOX HOST (where the NAS is mounted)
HOST_NAS_PATH=/mnt/pve/zima
# 4. SMB Credentials
SMB_USER=your_smb_user
SMB_PASSWORD=your_smb_password


# Cloudflare Ingress & Domain Config
CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
DOMAIN_NAME=example.com

# ProtonVPN Configuration
PROTONVPN_OPENVPN_USERNAME="your_protonvpn_openvpn_username"
PROTONVPN_OPENVPN_PASSWORD="your_protonvpn_openvpn_password"
PROTONVPN_SERVER_COUNTRIES='US'

# Headlamp Authentication
# Set your desired credentials for Headlamp Dashboard access
HEADLAMP_USERNAME="admin"
HEADLAMP_PASSWORD="YourStrongPasswordHere"

# Authelia (OIDC) Secrets
AUTHELIA_JWT_SECRET="your_jwt_secret"
AUTHELIA_SESSION_SECRET="your_session_secret"
AUTHELIA_STORAGE_ENCRYPTION_KEY="your_storage_encryption_key"

# QUI (qBittorrent Modern GUI) Authentication
QUI_USERNAME="admin"
QUI_PASSWORD="YourStrongPasswordHere"
ARGOCD_USERNAME='admin'
ARGOCD_PASSWORD='MySecretPassword123!'

# Notification System Secrets
NTFY_TOPIC="your_ntfy_topic_here"
