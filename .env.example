# Proxmox / LXC
MASTER_TARGET_NODE=pve
PROXMOX_ACCESS_HOST=proxmox.local
HAAC_MAINTENANCE_USER=haac-maint
# Optional fallback: if MASTER_TARGET_NODE already resolves from the workstation, PROXMOX_ACCESS_HOST may be left empty.
# `LXC_PASSWORD` is also the default Proxmox host password unless a caller explicitly overrides `PROXMOX_HOST_PASSWORD`.
LXC_PASSWORD=your_lxc_password
LXC_MASTER_HOSTNAME=haacarr-master
LXC_MASTER_MEMORY=6144
LXC_ROOTFS_DATASTORE=local-zfs
LXC_UNPRIVILEGED=true
LXC_NESTING=true
LXC_K3S_COMPAT_MODE=true
LXC_ENABLE_GPU_PASSTHROUGH=true
LXC_ENABLE_TUN=true
LXC_ENABLE_EBPF_MOUNTS=true
K3S_MASTER_IP=192.168.1.210/24
WORKER_NODES_JSON={"worker1":{"hostname":"haacarr-worker1","target_node":"pve","ip":"192.168.1.211/24","memory":8192,"cores":4,"labels":{}},"worker2":{"hostname":"haacarr-worker2","target_node":"pve","ip":"192.168.1.212/24","memory":4096,"cores":2,"labels":{}}}
# GPU discovery is handled by Node Feature Discovery; keep worker labels for custom placement only.
# Falco runtime is host-side on Proxmox. HAAC_FALCO_INGEST_NODEPORT is the stable cluster ingress that the host sensor forwards to.

# Storage / NAS
NAS_ADDRESS=192.168.1.20
NAS_PATH=/media/nvme1/proxmox
HOST_NAS_PATH=/mnt/pve/zima
NAS_SHARE_NAME=proxmox
SMB_USER=your_smb_user
SMB_PASSWORD=your_smb_password
STORAGE_UID=13000
STORAGE_GID=13000

# DNS / ingress
DOMAIN_NAME=example.com
GITOPS_REPO_URL=https://github.com/daubog44/arr_setup.git
GITOPS_REPO_REVISION=main
HAAC_WSL_DISTRO=Debian
HAAC_SSH_HOST_KEY_CHECKING=accept-new
HAAC_SSH_KNOWN_HOSTS_PATH=.ssh/known_hosts
HAAC_TOFU_VERSION=1.11.5
HAAC_HELM_VERSION=4.1.3
HAAC_KUBECTL_VERSION=1.35.3
HAAC_CLUSTER_KUBECTL_IMAGE_TAG=v1.35.2
HAAC_K3S_VERSION=v1.34.5+k3s1
HAAC_STATEFUL_STORAGE_CLASS=local-path
HAAC_ENABLE_K3S_AUTO_UPGRADES=false
HAAC_ENABLE_CLOUDFLARED_AUTOUPDATE=true
HAAC_ENABLE_FALCO=false
HAAC_FALCO_INGEST_NODEPORT=32081
HAAC_KUBESEAL_VERSION=0.36.1
HAAC_SEALED_SECRETS_CONTROLLER_VERSION=0.36.6
HAAC_TASK_VERSION=3.49.1
HAAC_POTTER_VERBOSITY=minimal
# Keep the in-cluster kubectl image aligned with the cluster minor version even if the local kubectl binary tracks latest stable.
PYTHON_CMD=python

# Cloudflare
CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id

# ProtonVPN / downloader networking
PROTONVPN_OPENVPN_USERNAME=your_protonvpn_openvpn_username
PROTONVPN_OPENVPN_PASSWORD=your_protonvpn_openvpn_password
PROTONVPN_SERVER_COUNTRIES=US
VPN_POD_SUBNET=10.42.0.0/16
VPN_SVC_SUBNET=10.43.0.0/16
VPN_DNS_IP=1.1.1.1

# Main operator identity defaults
# These seed the human login defaults for the control-plane/admin surfaces:
# Authelia, ArgoCD local auth, Grafana local admin, Semaphore admin, and Litmus admin.
HAAC_MAIN_USERNAME=haacadmin
HAAC_MAIN_PASSWORD=YourStrongPasswordHere
HAAC_MAIN_EMAIL=haacadmin@example.com
HAAC_MAIN_NAME=HaaC Admin

# Downloader local auth stays explicit on purpose.
# Set HAAC_ENABLE_SHARED_DOWNLOADER_CREDENTIALS=true only if you intentionally
# want qBittorrent and QUI to inherit HAAC_MAIN_* when their dedicated vars are unset.
# Unified-login mode example:
# HAAC_ENABLE_SHARED_DOWNLOADER_CREDENTIALS=true
# # Then QBITTORRENT_USERNAME and QUI_PASSWORD may stay unset to inherit HAAC_MAIN_*.
HAAC_ENABLE_SHARED_DOWNLOADER_CREDENTIALS=false
# Recommended default: keep downloader auth separate.
QBITTORRENT_USERNAME=admin
QUI_PASSWORD=YourDownloaderPasswordHere

# Service-specific login overrides (optional)
# Leave these unset to inherit the main operator identity defaults above.
# Optional local ArgoCD fallback auth. OIDC remains the primary login path.
# ARGOCD_USERNAME=haacadmin
# ARGOCD_PASSWORD=YourStrongPasswordHere
# AUTHELIA_ADMIN_USERNAME=haacadmin
# AUTHELIA_ADMIN_PASSWORD=YourStrongPasswordHere
# GRAFANA_ADMIN_USERNAME=haacadmin
# GRAFANA_ADMIN_PASSWORD=YourStrongPasswordHere
# LITMUS_ADMIN_USERNAME=haacadmin
# LITMUS_ADMIN_PASSWORD=YourStrongPasswordHere
# Litmus MongoDB credentials are technical secrets for the ChaosCenter backend.
# Keep the root password aligned with the pinned chart secret unless you intentionally reset Litmus data.
LITMUS_MONGODB_ROOT_PASSWORD=1234
LITMUS_MONGODB_REPLICA_SET_KEY=ChangeMeToALongStableRandomValue
# SEMAPHORE_ADMIN_USERNAME=haacadmin
# SEMAPHORE_ADMIN_PASSWORD=YourStrongPasswordHere
# SEMAPHORE_ADMIN_EMAIL=haacadmin@example.com
# SEMAPHORE_ADMIN_NAME=HaaC Admin

# Authelia core secrets
AUTHELIA_JWT_SECRET=your_jwt_secret
AUTHELIA_SESSION_SECRET=your_session_secret
AUTHELIA_STORAGE_ENCRYPTION_KEY=your_storage_encryption_key
AUTHELIA_ADMIN_PASSWORD_HASH=your_authelia_admin_password_hash
AUTHELIA_OIDC_PRIVATE_KEY_B64=base64_encoded_private_key

# OIDC client secrets
SEMAPHORE_OIDC_SECRET=semaphore-secret-123
GRAFANA_OIDC_SECRET=grafana-secret-123
ARGOCD_OIDC_SECRET=argocd-secret-123

# App and platform opaque secrets
SEMAPHORE_DB_PASSWORD=your_semaphore_db_password
SEMAPHORE_APP_SECRET=your_semaphore_app_secret
SEMAPHORE_COOKIE_HASH=your_semaphore_cookie_hash
SEMAPHORE_COOKIE_ENCRYPTION=your_semaphore_cookie_encryption
NTFY_TOPIC=your_ntfy_topic
