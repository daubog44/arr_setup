{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticPrefixFixDepsChoreOthers"
  ],
  "kubernetes": {
    "managerFilePatterns": [
      "/\\.yaml$/"
    ]
  },
  "helmv3": {
    "managerFilePatterns": [
      "/(^|/)Chart\\.yaml$/"
    ]
  },
  "packageRules": [
    {
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch"
      ],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "matchPackageNames": [
        "ghcr.io/linuxserver/*",
        "lscr.io/linuxserver/*",
        "ghcr.io/hotio/*"
      ],
      "groupName": "linuxserver-media-apps",
      "automerge": true
    },
    {
      "matchPackageNames": [
        "argoproj/argo-cd"
      ],
      "groupName": "argocd",
      "automerge": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["\\.yaml$", "Taskfile\\.yml$", "\\.sh$", "playbook\\.yml$"],
      "matchStrings": [
        "image:\\s*(?<depName>[^\\s:]+):(?<currentValue>[^\\s\"']+)",
        "# renovate: datasource=(?<datasource>[a-z-]+?) depName=(?<depName>[^\\s]+?)(?: versioning=(?<versioning>[^\\s]+?))?\\s+.*?[:=]\\s*\"?(?<currentValue>[^\\s\"']+)\"?"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "fileMatch": ["playbook\\.yml$", "Taskfile\\.yml$", "\\.sh$"],
      "matchStrings": [
        "https://github\\.com/(?<depName>[^/]+/[^/]+)/releases/download/(?<currentValue>v?[0-9.]+)/",
        "https://raw\\.githubusercontent\\.com/(?<depName>[^/]+/[^/]+)/(?<currentValue>v?[0-9.]+)/"
      ],
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "fileMatch": ["\\.yaml$"],
      "matchStrings": [
        "# renovate: registryUrl=(?<registryUrl>[^\\s]+) chart=(?<depName>[^\\s]+)\\s+targetRevision: \"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "helm"
    }
  ]
}
